    <string name="helpNavTitle">"Navigeren"</string>
    <string name="helpNavIntro">"Veeg naar links of rechts — of tik op een pictogram in de onderste balk — om tussen de vier hoofdschermen te wisselen. Meer opent alleen met een tik."</string>
    <string name="helpDestSignature">"Galactische Signatuur — de kin van vandaag, zijn toon en zegel."</string>
    <string name="helpDestOracle">"Bestemmingsorakel — het orakel van vijf zegels plus het verborgen PSI-zegel (Akasha)."</string>
    <string name="helpDestWavespell">"Wavespell — de golf van 13 dagen van de huidige kin."</string>
    <string name="helpDestTzolkin">"Tzolkin — de volledige harmonische module van 260 kin."</string>
    <string name="helpDestMore">"Meer — 13-Manenkalender, maanfase, Holon en de codex."</string>
    <string name="helpDayTitle">"De dag wijzigen"</string>
    <string name="helpDayBody">"De ‹ Vandaag ›-kiezer onderaan gaat één dag terug of vooruit. Vandaag blijft gedimd zolang je op vandaag bent en wordt goud zodra je verder gaat — tik erop om terug te springen. Voor een verre datum tik je op het kalenderpictogram in de bovenste balk en kies je een dag."</string>
    <string name="helpTapTitle">"Een signatuur lezen"</string>
    <string name="helpTapBody">"Tik op een glyph of toon om de naam, betekenis en kleurfamilie te zien. Zegels behouden hun traditionele kleuren — rood, wit, blauw en geel — en de tonen hun galactische goud."</string>
    <string name="helpSettingsTitle">"Instellingen"</string>
    <string name="helpSettingsBody">"Open het tandwiel in de bovenste balk om de taal te wijzigen, te kiezen hoe het PSI-zegel (Akasha) wordt getoond en te lezen wat er nieuw is in deze versie."</string>
