<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded card surface for palette-themed dialogs (P0-1). -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="14dp" android:insetRight="14dp" android:insetTop="18dp" android:insetBottom="18dp">
    <shape android:shape="rectangle">
        <solid android:color="@color/mw_card" />
        <corners android:radius="18dp" />
        <stroke android:width="1dp" android:color="@color/mw_amethyst_line" />
    </shape>
</inset>
