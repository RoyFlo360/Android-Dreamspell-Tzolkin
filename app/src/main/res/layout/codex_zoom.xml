<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/mw_obsidian">

    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/mw_amethyst" android:paddingStart="16dp" android:paddingEnd="6dp">
        <TextView android:id="@+id/codexTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/mw_cream" android:paddingTop="14dp" android:paddingBottom="14dp" />
        <ImageButton android:id="@+id/codexClose" android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/abc_ic_clear_material" android:tint="@color/mw_cream"
            android:background="?android:attr/selectableItemBackgroundBorderless" android:contentDescription="@string/btClose" />
    </LinearLayout>

    <com.imix.dreamspell_tzolkin.controller.views.ZoomStackView android:id="@+id/codexZoom"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:background="@color/codex_bg" />
</LinearLayout>
